{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "money": {
      "type": "object",
      "required": ["amount", "currency"],
      "properties": {
        "amount": { "type": "number", "minimum": 0 },
        "currency": { "enum": ["USD", "EUR", "GBP", "JPY", "AUD"] }
      },
      "additionalProperties": false
    },
    "address": {
      "type": "object",
      "required": ["street", "city", "country"],
      "properties": {
        "street": { "type": "string", "minLength": 1 },
        "city": { "type": "string", "minLength": 1 },
        "country": { "type": "string", "minLength": 2, "maxLength": 2 },
        "postcode": { "type": "string" }
      }
    },
    "lineItem": {
      "allOf": [
        {
          "type": "object",
          "required": ["sku", "qty", "price"],
          "properties": {
            "sku": { "type": "string", "pattern": "^[A-Z]{2,4}-[0-9]{3,6}$" },
            "qty": { "type": "integer", "minimum": 1 },
            "price": { "$ref": "#/$defs/money" }
          }
        },
        {
          "anyOf": [
            { "properties": { "discount": { "$ref": "#/$defs/money" } }, "required": ["discount"] },
            { "not": { "required": ["discount"] } }
          ]
        }
      ]
    },
    "party": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "billing": { "$ref": "#/$defs/address" },
        "shipping": { "$ref": "#/$defs/address" }
      }
    }
  },
  "type": "object",
  "required": ["orderId", "buyer", "seller", "items", "total"],
  "properties": {
    "orderId": { "type": "string", "pattern": "^ORD-[0-9]{8}$" },
    "buyer": { "$ref": "#/$defs/party" },
    "seller": { "$ref": "#/$defs/party" },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/lineItem" }
    },
    "total": { "$ref": "#/$defs/money" },
    "status": {
      "oneOf": [
        { "const": "draft" },
        { "const": "placed" },
        { "const": "shipped" },
        { "const": "delivered" },
        { "const": "cancelled" }
      ]
    }
  },
  "additionalProperties": false
}
